# Copy to .env and fill in. Never commit .env.

# --- Alpaca (paper trading) ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Live trading gate ---
# Must be "true" AND ./ARMED file must exist with today's date for live mode.
LIVE_TRADING=false

# --- Research ---
PERPLEXITY_API_KEY=

# --- Notifications (optional) ---
# If either is missing, notify.py falls back to stdout.
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=

# --- Runtime ---
# Set to "true" to print verbose logs
DEBUG=false
